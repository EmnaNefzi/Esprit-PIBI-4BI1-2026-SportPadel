    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT&#xD;&#xA;  sku,&#xD;&#xA;  title AS modele,&#xD;&#xA;  vendor AS marque,&#xD;&#xA;  price AS prix,&#xD;&#xA;  CASE&#xD;&#xA;    WHEN CAST(price AS numeric) &lt; 100 THEN '&lt; 100 TND'&#xD;&#xA;    WHEN CAST(price AS numeric) >= 100 AND CAST(price AS numeric) &lt; 200 THEN '100-200 TND'&#xD;&#xA;WHEN CAST(price AS numeric) >= 200 THEN '>200 TND'&#xD;&#xA;    ELSE 'Non renseigne'&#xD;&#xA;  END AS categorie_prix&#xD;&#xA;FROM sa.sa_padel_rackets&#xD;&#xA;WHERE product_type = 'Raquettes'&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
