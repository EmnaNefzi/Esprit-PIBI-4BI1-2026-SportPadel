      <elementValue elementRef="SCHEMA_COLUMN" value="sku"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="modele"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="marque"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="prix"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="categorie_prix"/>
      <elementValue elementRef="TRIM" value="false"/>
    </elementParameter>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
